@page "/"
@page "/advisor"
@inject DashboardDataService DataService

<PageTitle>Advisor · Caseload</PageTitle>

@if (_students is null)
{
    <p class="loading-state">Loading caseload…</p>
}
else
{
    var hierarchyFiltered = _selectedField is null ? _students : _students.Where(s => _selectedField switch
    {
        "faculty" => s.Faculty == _selectedValue,
        "department" => s.Department == _selectedValue,
        "career" => s.AcademicCareer == _selectedValue,
        "programme" => s.Programme == _selectedValue,
        _ => true,
    }).ToList();
    var filtered = _selectedYear is null ? hierarchyFiltered : hierarchyFiltered.Where(s => s.YearOfStudy == _selectedYear).ToList();
    var sorted = filtered.OrderByDescending(s => s.Risk).ToList();
    var years = hierarchyFiltered.Select(s => s.YearOfStudy).Distinct().OrderBy(y => y).ToList();

    <div class="body-layout">
        <HierarchyRail Students="@_students" SelectedField="@_selectedField" SelectedValue="@_selectedValue"
                        OnSelect="@(sel => { _selectedField = sel.Field; _selectedValue = sel.Value; _selectedYear = null; })"
                        OnReset="@(() => { _selectedField = null; _selectedValue = null; })" />

        <div class="roster-col">
            <div class="roster-head">
                <div>
                    <h1>Advisor caseload</h1>
                    <div class="roster-sub">@sorted.Count students · sorted by risk</div>
                </div>
                <div class="sort-control">
                    <select @onchange="OnYearChanged">
                        <option value="">All years of study</option>
                        @foreach (var y in years)
                        {
                            <option value="@y" selected="@(_selectedYear == y)">Year @y</option>
                        }
                    </select>
                </div>
            </div>
            <div class="roster-annot">
                Every currently-active student (year-outcome progressed/repeated) as of the most recent intake
                cohort's calendar year — not each student's final simulated row, which skews toward already-far-behind
                stragglers and silently excludes 1st/2nd-years. Capped to 15 highest + 5 lowest risk per department so
                every node in the hierarchy stays populated without shipping the full ~1,100-student snapshot. Each
                card also carries a separate delayed-graduation risk (Model C), trained only on graduated students'
                pre-entry profile and pace — never on year-of-study itself.
            </div>

            <div class="grid">
                @foreach (var s in sorted)
                {
                    <RiskCard @key="s.Id" Id="@s.Id" Subtitle="@s.Programme" Risk="@s.Risk" Tier="@s.Tier" Factors="@s.Factors"
                              Calculation="@s.Calculation" CalculationLabel="Year-failure model"
                              PaceBadge="@($"Year {s.YearOfStudy} of {s.MinYearsToComplete}")" PaceOverdue="@s.OverMinimumDuration"
                              SecondaryLabel="Delayed-graduation risk" SecondaryRisk="@s.DelayedGradRisk" SecondaryTier="@s.DelayedGradTier"
                              SecondaryCalculation="@s.DelayedGradCalculation" SecondaryCalculationLabel="Delayed-graduation model"
                              IsFlagged="@_flagged.Contains(s.Id)" IsLogged="@_logged.Contains(s.Id)"
                              OnToggleFlag="@(() => ToggleFlag(s.Id))" OnLogIntervention="@(() => LogIntervention(s.Id))"
                              OnCardClick="@(() => OpenDrawer(s.Id))" />
                }
                @if (sorted.Count == 0)
                {
                    <div class="empty-state">No students match this selection.</div>
                }
            </div>
        </div>
    </div>

    <StudentDrawer Student="@_openStudent"
                   IsFlagged="@(_openStudent is not null && _flagged.Contains(_openStudent.Id))"
                   IsLogged="@(_openStudent is not null && _logged.Contains(_openStudent.Id))"
                   OnClose="CloseDrawer"
                   OnToggleFlag="@(() => { if (_openStudent is not null) ToggleFlag(_openStudent.Id); })"
                   OnLogIntervention="@(() => { if (_openStudent is not null) LogIntervention(_openStudent.Id); })" />
}

@code {
    private List<AdvisorStudent>? _students;
    private int? _selectedYear;
    private string? _selectedField;
    private string? _selectedValue;
    private AdvisorStudent? _openStudent;
    private readonly HashSet<string> _flagged = [];
    private readonly HashSet<string> _logged = [];

    protected override async Task OnInitializedAsync()
    {
        var data = await DataService.GetDashboardDataAsync();
        _students = data.Advisor.Students;
    }

    private void OpenDrawer(string id) => _openStudent = _students!.First(s => s.Id == id);
    private void CloseDrawer() => _openStudent = null;

    private void OnYearChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        _selectedYear = string.IsNullOrEmpty(value) ? null : int.Parse(value);
    }

    private void ToggleFlag(string id)
    {
        if (!_flagged.Add(id)) _flagged.Remove(id);
    }

    private void LogIntervention(string id) => _logged.Add(id);
}
